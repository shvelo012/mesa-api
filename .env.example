DB_HOST=localhost
DB_PORT=5432
DB_NAME=restaurant_reservation
DB_USER=your_db_user
DB_PASSWORD=your_db_password
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
# Public URL of THIS API — must be reachable by the banks for payment callbacks
API_PUBLIC_URL=http://localhost:4000

# AES-256-GCM key for encrypting SMTP passwords stored in DB
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SMTP_ENCRYPTION_KEY=your-64-char-hex-key-here

# ── Email (SMTP) ──────────────────────────────────────────────
# If unset, emails are printed to console (safe for local dev).
#
# Dev — Gmail App Password:
#   1. Enable 2-Step Verification: myaccount.google.com/security
#   2. Create App Password → copy the 16-char code
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM=Mesa Dev <you@gmail.com>
#
# Prod — set these to your transactional provider (Resend, SendGrid, etc.)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxx
# SMTP_FROM=Mesa <noreply@yourdomain.com>

# ── Payments (Georgian banks) ─────────────────────────────────
# Credentials are issued by each bank after merchant onboarding.
# Recurring/saved-card tokens are encrypted at rest with SMTP_ENCRYPTION_KEY.
#
# Local testing with no bank credentials: set PAYMENT_MOCK=1 to route all
# payments through a local fake-bank page (mounts /api/payments/mock/*).
# NEVER enable in production.
PAYMENT_MOCK=0
#
# TBC E-Commerce (tpay)
TBC_API_BASE=https://api.tbcbank.ge/v1/tpay
TBC_API_KEY=your-tbc-apikey
TBC_CLIENT_ID=your-tbc-client-id
TBC_CLIENT_SECRET=your-tbc-client-secret
#
# Bank of Georgia (BOG)
BOG_AUTH_URL=https://oauth2.bog.ge/auth/realms/bog/protocol/openid-connect/token
BOG_API_BASE=https://api.bog.ge/payments/v1
BOG_CLIENT_ID=your-bog-client-id
BOG_CLIENT_SECRET=your-bog-client-secret
# BOG's published PEM public key for verifying callback signatures
# (use \n for newlines if your env loader needs single-line values)
BOG_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
